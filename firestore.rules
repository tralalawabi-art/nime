rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false; // Users cannot be deleted from the client SDK
    }

    // 2. Bookmarks collection rules
    match /bookmarks/{bookmarkId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // 3. Watch History collection rules
    match /history/{historyId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // 4. Comments collection rules
    match /comments/{commentId} {
      allow read: if true; // Comments are publicly readable
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
